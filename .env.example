# Copy to .env and fill in. .env is gitignored — never commit real keys.
GEMINI_API_KEY=your-google-ai-studio-key

# Competitor outlier research (scripts/fetch_outliers.py) — YouTube Data API v3.
# Free tier (10,000 units/day), NO billing needed; from console.cloud.google.com,
# not AI Studio. See docs/outlier_system.md.
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# Optional: formula tagging (scripts/tag_outliers.py) — pay-per-use, gated by --yes.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Kling no longer needs API keys here: it's connected as an MCP (custom connector,
# https://kling.ai/mcp), so its authorization lives in Claude's connector settings.
